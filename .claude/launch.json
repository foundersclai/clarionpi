{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "clarionpi-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 3400
    },
    {
      "name": "clarionpi-backend",
      "runtimeExecutable": "backend/.venv/bin/uvicorn",
      "runtimeArgs": ["app.main:app", "--app-dir", "backend", "--port", "8400"],
      "port": 8400
    }
  ]
}
