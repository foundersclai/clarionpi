# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Env
.env

# Node (frontend lands at M3)
node_modules/
dist/

# OS
.DS_Store

# local databases
*.db

# Per-matter run logs (runtime artifacts, never committed)
logs/
backend/logs/

# Local object-storage roots — ingest blobs (dev + workshop); runtime artifacts, never committed
var/
backend/var/

# Workshop demo — generated scenario PDFs (regenerate via each scenario's generate.py)
workshop/**/pdf/

# Workshop driver — per-run resume state (holds a matter id; runtime artifact, never committed)
backend/scripts/.workshop_drive_state.json
