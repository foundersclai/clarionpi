# Copy to .env and adjust as needed. No secrets belong in this file or in .env
# (which is gitignored) beyond throwaway local-dev defaults.

# Postgres connection. Port 5433 (not 5432) to avoid colliding with any other
# local Postgres instance — see deploy/docker-compose.yml.
DATABASE_URL=postgresql://clarionpi:clarionpi_dev@localhost:5433/clarionpi

# Object store (MinIO in dev; S3-compatible in prod). Matches
# deploy/docker-compose.yml's minio service defaults.
OBJECT_STORE_ENDPOINT=http://localhost:9400
OBJECT_STORE_KEY=clarionpi
OBJECT_STORE_SECRET=clarionpi_dev_secret

# Runtime environment: dev | staging | prod.
APP_ENV=dev

# Auth mode (M3 Wave A): session | stub. "session" = real login (argon2 password +
# server-side opaque-token session cookie). "stub" = the seeded dev attorney with no login
# (non-prod dev/test convenience only; the startup dev-user seed is refused when APP_ENV=prod).
AUTH_MODE=stub
# Session lifetime in minutes (720 = 12h). Bounds the cookie max-age and the DB expiry.
SESSION_TTL_MINUTES=720

# Default per-matter spend ceiling, in integer cents (all money in ClarionPI is
# integer cents — see app/money). 2500 = $25.00.
MATTER_BUDGET_DEFAULT_CENTS=2500

# --- Corpus ingest (M1) ------------------------------------------------------

# Object-store backend for case blobs. Only "local" is implemented at M1
# (disk-backed); S3/MinIO lands with the prod account.
STORAGE_BACKEND=local
# Root dir for the local storage backend (relative to the backend working dir).
STORAGE_ROOT=./var/storage
# Minutes an abandoned upload session survives before the sweep expires it.
UPLOAD_SESSION_TTL_MINUTES=1440
# Upload registration limits (upload-safety audit SEC-05). All three must be positive —
# a zero/negative value is refused at settings load. Registration over any bound returns a
# typed 413 (upload_limit_exceeded + which limit); the slot PUT enforces the per-file bound
# again against ACTUAL streamed bytes.
UPLOAD_MAX_FILES_PER_SESSION=200
UPLOAD_MAX_BYTES_PER_FILE=104857600
UPLOAD_MAX_BYTES_PER_SESSION=1073741824

# OCR engine for image-only pages: none | fake | tesseract. The tesseract binary
# is absent on the bootstrap machine; "none"/"fake" need no binary.
OCR_ENGINE=none
# Minimum chars of stripped text-layer text for a page to skip OCR.
TEXT_DENSITY_FLOOR=32

# LLM provider selector for app composition: null | anthropic. "null" (default) makes
# classification/extraction degrade to the review queue via ProviderNotConfigured — visible,
# not silent. "anthropic" wires a live Anthropic /v1/messages client (requires ANTHROPIC_API_KEY)
# so S2 evals can run with a key; it is still metered-door-only (MeteredLLMClient calls it).
LLM_PROVIDER=null
# Anthropic API key. Only read when LLM_PROVIDER=anthropic; the provider raises at construction
# if it is unset/blank. Never commit a real key.
ANTHROPIC_API_KEY=

# Classifier model + sampling. Confidence floor is a score, not currency.
CLASSIFIER_MODEL=claude-haiku-4-5
CLASSIFIER_SAMPLE_PAGES=3
CLASSIFIER_CONFIDENCE_FLOOR=0.7

# Dedup shingling: words per shingle + Jaccard overlap threshold (a score).
SHINGLE_SIZE=5
SHINGLE_OVERLAP_THRESHOLD=0.35

# Root dir for per-matter run logs (invariant 14: debugging starts at the logs).
MATTER_LOGS_DIR=./logs/matters

# --- Extraction (M2) ---------------------------------------------------------

# Per-stage models for the M2 extractors. Extractor = structured medical/billing/incident
# extraction; narrative = tokenized encounter narratives; merge_tiebreak = ambiguous-merge
# adjudication.
EXTRACTOR_MODEL=claude-sonnet-5
NARRATIVE_MODEL=claude-sonnet-5
MERGE_TIEBREAK_MODEL=claude-sonnet-5
# Extraction windowing: pages per window and pages of overlap between adjacent windows.
EXTRACTION_WINDOW_PAGES=8
EXTRACTION_WINDOW_OVERLAP=2
# Per-call output-token ceiling sent as max_tokens on the Anthropic /v1/messages request.
LLM_MAX_OUTPUT_TOKENS=4096

# --- Risk flags (M4) ---------------------------------------------------------

# Treatment-gap threshold: a pre-MMI gap wider than this many days flags. A day count, not money.
TREATMENT_GAP_MAX_DAYS=30
# Below this property-damage figure ($1,500 default), any injury treatment trips a
# low-property-damage flag. Integer CENTS (money boundary); calibration pending.
LOW_PROPERTY_DAMAGE_THRESHOLD_CENTS=150000
# Flood guard: max flags surfaced per kind. Capped flags are still surfaced, never dropped.
RISK_FLAG_PER_KIND_CAP=12
# Model for the LLM risk-labeling pass.
RISK_LABEL_MODEL=claude-sonnet-5

# --- Brain-2 / G3 (M5) -------------------------------------------------------

# Model tiering for drafting + compliance. The drafter (per-section prose) and the strategy
# memo run on Opus (intelligence/synthesis tier); the compliance judge runs on Sonnet (semantic
# verdict grader).
DRAFTER_MODEL=claude-opus-4-8
JUDGE_MODEL=claude-sonnet-5
MEMO_MODEL=claude-opus-4-8

# --- Package build (M5 Wave B2) ----------------------------------------------

# Bates prefix stamped on binder pages (e.g. "CP00001"). A short firm-scoped label, not money.
BATES_PREFIX=CP
