# ClarionPI workshop env template. Copy to backend/.env (gitignored) and fill the key:
#
#     cp backend/.env.example backend/.env      # then edit ANTHROPIC_API_KEY
#
# `make workshop-backend` / `make workshop-up` source backend/.env before starting uvicorn.
# Only the live-model credentials belong here — the Makefile sets APP_ENV / AUTH_MODE /
# DATABASE_URL / STORAGE_ROOT / CSRF origins for the workshop.
#
# Enables the pre-run model beats (ingest, classification, extraction, analysis, drafting).
# Leave LLM_PROVIDER=null (or omit backend/.env entirely) to run fully offline.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
